<script>
  // ===== PIN =====
  const PIN = '8291';
  let entered = '';

  function renderDots() {
    for (let i = 0; i < 4; i++) {
      const d = document.getElementById('d' + i);
      d.classList.toggle('filled', i < entered.length);
      d.classList.remove('error');
    }
  }

  function pinPress(digit) {
    if (entered.length >= 4) return;
    entered += digit;
    renderDots();
    if (entered.length === 4) setTimeout(checkPin, 180);
  }

  function pinDelete() {
    entered = entered.slice(0, -1);
    renderDots();
    document.getElementById('pin-err').textContent = '';
  }

  function checkPin() {
    if (entered === PIN) {
      document.getElementById('pin-screen').style.display = 'none';
      document.getElementById('app').removeAttribute('hidden');
    } else {
      document.getElementById('pin-err').textContent = 'Incorrect PIN — try again';
      for (let i = 0; i < 4; i++) document.getElementById('d' + i).classList.add('error');
      const dots = document.getElementById('pin-dots');
      dots.classList.remove('shake');
      void dots.offsetWidth; // reflow
      dots.classList.add('shake');
      entered = '';
      setTimeout(() => {
        renderDots();
        dots.classList.remove('shake');
      }, 500);
    }
  }

  // Keyboard support
  document.addEventListener('keydown', e => {
    if (document.getElementById('app').hidden) {
      if (e.key >= '0' && e.key <= '9') pinPress(e.key);
      if (e.key === 'Backspace') pinDelete();
      if (e.key === 'Enter' && entered.length === 4) checkPin();
    }
  });

  // ===== ACCORDION =====
  function tog(btn) {
    btn.closest('.section').classList.toggle('open');
  }

  // ===== SEARCH =====
  function handleSearch(q) {
    q = q.toLowerCase().trim();
    const sections = document.querySelectorAll('#sections .section');
    let visible = 0;

    sections.forEach(sec => {
      if (!q) {
        sec.classList.remove('hidden');
        visible++;
        return;
      }
      const title = sec.querySelector('.sec-title').textContent.toLowerCase();
      const meta  = (sec.dataset.s || '').toLowerCase();
      const body  = sec.querySelector('.sec-body').textContent.toLowerCase();
      const match = title.includes(q) || meta.includes(q) || body.includes(q);

      if (match) {
        sec.classList.remove('hidden');
        sec.classList.add('open');
        visible++;
      } else {
        sec.classList.add('hidden');
      }
    });

    document.getElementById('no-results').style.display = visible === 0 ? 'block' : 'none';
  }
</script>

